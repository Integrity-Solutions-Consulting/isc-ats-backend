# Copy to .env and adjust. Defaults target the docker-compose database.
# In production (Dokploy) set every value below as an environment variable.

# Application
APP_NAME="ISC ATS Backend"
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Database (async driver: postgresql+asyncpg)
# docker-compose maps pgvector/pgvector:pg18 to host port 5433.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/isc_ats
# Echo SQL statements (separate from DEBUG). Keep false in production.
SQL_ECHO=false

# Security
# IMPORTANT: the app refuses to boot in production with this default value.
# Generate a strong random secret for each environment.
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# MinIO / S3 object storage (candidate CVs, generated documents)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=candidates-cvs
# Enable TLS in production.
MINIO_SECURE=false

# AI / LLM providers (leave empty to disable the related features)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
