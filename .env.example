# Copy to .env and adjust. Defaults target the docker-compose database.
# In production (Dokploy) set every value below as an environment variable.

# Application
APP_NAME="ISC ATS Backend"
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Database (async driver: postgresql+asyncpg)
# docker-compose maps pgvector/pgvector:pg18 to host port 5433.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/isc_ats
# Echo SQL statements (separate from DEBUG). Keep false in production.
SQL_ECHO=false

# Security
# IMPORTANT: the app refuses to boot in production with this default value.
# Generate a strong random secret for each environment.
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Trust the X-Real-Client-IP header (set by the Next.js proxy) for per-IP rate
# limiting and audit. Set true ONLY in production where the backend is reachable
# only through the proxy (Dokploy internal network). Keep false locally.
TRUST_PROXY_HEADERS=false

# MinIO / S3 object storage (candidate CVs, generated documents)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=candidates-cvs
# Enable TLS in production.
MINIO_SECURE=false

# AI / LLM providers (leave empty to disable the related features)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Email
# Active transport: "smtp" (Gmail, today) or "resend" (future, needs a verified domain).
EMAIL_PROVIDER=smtp
# Public frontend URL used to build links inside emails (no trailing slash).
FRONTEND_BASE_URL=http://localhost:3000
# Sender identity shown to recipients.
EMAIL_SENDER_NAME="Integrity Solutions"
EMAIL_SENDER_EMAIL=soporteintegritysolutions@gmail.com
# SMTP / Gmail. SMTP_PASSWORD is a Gmail APP-PASSWORD (Google Account > Security >
# App passwords), never the account password. Regenerate it if it ever leaks.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=soporteintegritysolutions@gmail.com
SMTP_PASSWORD=
# Resend (future). Set EMAIL_PROVIDER=resend and fill this once the domain is verified.
RESEND_API_KEY=

# Meetings (Teams via Microsoft Graph)
# "disabled" (default) or "graph". For "graph" register an Azure AD app with
# application permission OnlineMeetings.ReadWrite.All (admin consent) + a Teams
# application access policy authorizing the organizer's account.
MEETINGS_PROVIDER=disabled
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
